# -----------------------------------------------------------------------------
# ReadQuest - environment variables template
# Copy this file to .env.local and fill in your project-specific values.
# NEVER commit .env.local to version control.
# -----------------------------------------------------------------------------

# Supabase project URL (Settings -> API -> Project URL)
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (Settings -> API -> anon public)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Local backend for book knowledge
READQUEST_API_PORT=8787
VITE_API_BASE_URL=http://localhost:8787
BRAVE_SEARCH_API_KEY=your_brave_search_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_HYBRID_MODEL=gemini-3.1-flash-lite
GEMINI_HYBRID_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_RECOMMENDATION_MODEL=gemini-3.1-flash-lite
GEMINI_CONSISTENCY_MODEL=gemini-3.1-flash-lite

# Optional: Groq API (legacy copilot experiments)
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_MODEL=llama-3.1-8b-instant

# Optional: feature flags (true/false)
VITE_FF_AI_COPILOT=true
VITE_FF_READING_FOCUS_TIMER=true
VITE_FF_WEEKLY_GOAL=true
VITE_FF_RETENTION_METRICS=true
VITE_FF_SMART_RECOMMENDATIONS=true
